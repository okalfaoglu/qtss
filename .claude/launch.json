{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173
    },
    {
      "name": "web-v2-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--prefix", "web-v2"],
      "port": 5174,
      "autoPort": true
    },
    {
      "name": "api-server",
      "runtimeExecutable": "cargo",
      "runtimeArgs": ["run", "-p", "qtss-api"],
      "port": 8080
    },
    {
      "name": "worker",
      "runtimeExecutable": "cargo",
      "runtimeArgs": ["run", "-p", "qtss-worker"]
    }
  ]
}
