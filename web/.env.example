# Bu dosyayı kopyalayıp adını `.env` yapın:  cp .env.example .env
# Sonra aşağıdaki CHANGEME alanlarını seed çıktınızla doldurun.

VITE_OAUTH_CLIENT_ID=qtss-cli
# Seed çıktısı: OAuth client_secret=...
VITE_OAUTH_CLIENT_SECRET=CHANGEME_seed_client_secret_buraya
# Seed ile aynı admin e-posta (varsayılan admin@localhost)
VITE_DEV_EMAIL=admin@localhost
# QTSS_SEED_ADMIN_PASSWORD ile aynı
VITE_DEV_PASSWORD=CHANGEME_admin_parola_buraya

# Sorun giderme: Konsolda POST …/oauth/token 401 görüyorsanız backend çoğunlukla
# invalid_client döndürüyordur → VITE_OAUTH_CLIENT_ID=qtss-cli ve özellikle
# VITE_OAUTH_CLIENT_SECRET, `cargo run -p qtss-api --bin qtss-seed` çıktısındaki
# satırla birebir aynı olmalı. Seed’i yeniden çalıştırdıysanız yeni secret’ı .env’e yazın;
# .env değiştikten sonra `npm run dev`’i yeniden başlatın.

# Grafik varsayılanları (üst menü ilk yükleme)
VITE_DEFAULT_EXCHANGE=binance
VITE_DEFAULT_SEGMENT=spot
VITE_DEFAULT_SYMBOL=BTCUSDT
VITE_DEFAULT_INTERVAL=15m
VITE_DEFAULT_BAR_LIMIT=1000
# Binance 1000 mum/istek üst sınırı; daha uzun geçmiş için kaç ek sayfa (1000’lik) çekileceği.
# VITE_BINANCE_KLINE_MAX_PAGES=50
# Canlı son mum birleştirme (ms). 0 = kapalı (zoom korunur; poll devre dışı).
# VITE_LIVE_POLL_MS=5000
# Üst şerit: tüm TF’lerde son mum anlık % (ayrı poll; çok istek). 0 = şerit gizlenir. Varsayılan 3000.
# VITE_MTF_LIVE_POLL_MS=3000

# İsteğe bağlı: proxy yerine doğrudan API (örn. WSL dışından)
# VITE_API_BASE=http://127.0.0.1:8080

# Geliştirme — Vite `/__binance` köprüsünün hedefi (varsayılan https://api.binance.com).
# Bazı bölgelerde (örn. TR) doğrudan Binance IP’si engellenebilir; Vite süreci de isteği oraya atar.
# Aynı yolu (/api/v3/klines …) iletebilen erişilebilir bir taban URL yazın (VPN/relay/kendi backend).
# VITE_BINANCE_PROXY_TARGET=https://ornek-kopru.example.com
#
# Alternatif: tarayıcı isteğini doğrudan CORS izinli bir tabana yönlendir (Vite proxy atlanır).
# VITE_BINANCE_API_BASE=https://...

# Giriş varken OHLC’yi tarayıcıdan Binance’e değil QTSS API üzerinden çek (qtss-binance connector).
# `VITE_API_BASE` veya Vite `/api` proxy’si backend’e gitmeli. JWT + dashboard rolü gerekir.
# VITE_BINANCE_KLINES_VIA_API=1

# Grafik OHLC kaynağı: auto | exchange | database (localStorage ile üst çubuktan da değişir)
# VITE_CHART_OHLC_MODE=auto
