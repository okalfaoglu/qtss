# Proje kökünde `.env` olarak kopyalayın:  cp .env.example .env
# `cargo run -p qtss-api`, `qtss-seed`, `qtss-worker` başlarken otomatik yüklenir.
# Bu dosyayı git'e vermeyin; `.env` zaten .gitignore'da.

DATABASE_URL=postgres://qtss:PAROLA@127.0.0.1:5432/qtss
# En az 32 karakter (openssl rand -base64 48)
QTSS_JWT_SECRET=BURAYA_UZUN_RASTGELE

# API
# QTSS_BIND=0.0.0.0:8080

# Seed (yalnızca qtss-seed)
# QTSS_SEED_ADMIN_PASSWORD=

# qtss-worker — canlı mum → market_bars (systemd ile sürekli çalıştırmak için deploy/README.md)
# QTSS_KLINE_SYMBOL=BTCUSDT
# QTSS_KLINE_INTERVAL=1m
# QTSS_KLINE_SEGMENT=spot
