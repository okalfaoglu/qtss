# Copy to `.env` in the repo root. Only `DATABASE_URL` is defined here.
# All other settings: `system_config` and `app_config` (Admin UI, SQL seeds, migrations). See `docs/CONFIG_REGISTRY.md`.

DATABASE_URL=postgres://qtss:PAROLA@127.0.0.1:5432/qtss

# Optional overrides (see docs/CONFIG_REGISTRY.md). AI tactical executor live mode needs an account pair
# if the symbol has no prior fills in exchange_orders:
# QTSS_AI_TACTICAL_EXECUTOR_ORG_ID=<uuid>
# QTSS_AI_TACTICAL_EXECUTOR_USER_ID=<uuid>
