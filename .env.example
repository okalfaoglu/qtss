# Proje kökünde `.env` olarak kopyalayın:  cp .env.example .env
# `cargo run -p qtss-api`, `qtss-seed`, `qtss-worker` başlarken otomatik yüklenir.
# Bu dosyayı git'e vermeyin; `.env` zaten .gitignore'da.
#
# İsteğe bağlı log: `RUST_LOG` tanımlıysa kod içi varsayılan dizgeyi override eder — tam dizgeler §2.1, özet §5 (`docs/QTSS_CURSOR_DEV_GUIDE.md`)
# qtss-worker varsayılanına yakın örnek:
# RUST_LOG=info,qtss_worker=debug,sqlx::postgres::notice=warn
# qtss-api varsayılanına yakın örnek:
# RUST_LOG=info,qtss_api=debug,qtss_storage=debug,tower_http=info,sqlx::postgres::notice=warn
# QTSS_LOG_JSON=1

DATABASE_URL=postgres://qtss:PAROLA@127.0.0.1:5432/qtss
# HMAC anahtarı: en az 32 UTF-8 bayt (Unicode’da karakter başına bayt değişir; salt ASCII’de ≈ karakter sayısı). Örnek: openssl rand -base64 48
QTSS_JWT_SECRET=BURAYA_UZUN_RASTGELE
# JWT ile `user_permissions` birleştirmesini kapatmak için: 0 / false / off (varsayılan: birleştir açık)
# QTSS_JWT_MERGE_DB_PERMISSIONS=0
#
# FAZ 11.5 — Merkezi config: yalnızca 1/true olduğunda bazı okuyucular env değerini DB yerine tercih edebilir (felaket kurtarma).
# QTSS_CONFIG_ENV_OVERRIDES=0

# API
# QTSS_BIND=0.0.0.0:8080
# Gözlemlenebilirlik / kube: GET /live (liveness, bağımlılık yok), GET /ready (PostgreSQL ping, 503 = hazır değil),
# GET /health (özet JSON), GET /metrics (isteğe bağlı koruma: aşağıdaki token).
# QTSS_METRICS_TOKEN=
# HTTP mutasyon audit_log: yalnızca tam olarak 1 iken açılır; tanımsız veya başka değer = kapalı (varsayılan kapalı).
# QTSS_AUDIT_HTTP=1

# Seed (yalnızca qtss-seed)
# QTSS_SEED_ADMIN_PASSWORD=

# qtss-worker — canlı mum → market_bars (systemd ile sürekli çalıştırmak için deploy/README.md)
# QTSS_KLINE_SYMBOL=BTCUSDT
# QTSS_KLINE_INTERVAL=1m
# QTSS_KLINE_SEGMENT=spot
#
# qtss-worker — isteğe bağlı sağlık uçları (`GET /live`, `GET /ready`); tanımsız veya boş = kapalı
# QTSS_WORKER_HTTP_BIND=127.0.0.1:9090
#
# qtss-worker — Binance spot açık emir mutabakatı (API POST /api/v1/reconcile/binance ile aynı mantık; exchange_accounts spot olan kullanıcılar)
# QTSS_RECONCILE_BINANCE_SPOT_ENABLED=0
# QTSS_RECONCILE_BINANCE_SPOT_TICK_SECS=3600
# Mutabakat sonrası `submitted` + açık listede yok → `reconciled_not_open` (varsayılan açık; kapat: 0/false/off)
# QTSS_RECONCILE_BINANCE_SPOT_PATCH_STATUS=0
# Açık emirde yok + `GET /api/v3/order` ile filled/canceled netleştirme (rate limit; varsayılan kapalı)
# QTSS_RECONCILE_BINANCE_SPOT_REFINE_ORDER_STATUS=1
# QTSS_RECONCILE_BINANCE_SPOT_REFINE_MAX=30
# QTSS_RECONCILE_BINANCE_FUTURES_ENABLED=0
# QTSS_RECONCILE_BINANCE_FUTURES_TICK_SECS=3600
# QTSS_RECONCILE_BINANCE_FUTURES_PATCH_STATUS=0
# QTSS_RECONCILE_BINANCE_FUTURES_REFINE_ORDER_STATUS=1
# QTSS_RECONCILE_BINANCE_FUTURES_REFINE_MAX=30
#
# qtss-worker — arka plan analiz (`engine_symbols` → `analysis_snapshots`)
# QTSS_ENGINE_TICK_SECS=120
# QTSS_ENGINE_BARS_LIMIT=1500
# QTSS_TR_LOOKBACK=50
# QTSS_TR_ATR_PERIOD=14
# QTSS_TR_ATR_SMA_PERIOD=50
# QTSS_TR_REQUIRE_RANGE_REGIME=0
#
# qtss-worker — confluence (teknik + on-chain + smart money) → `analysis_snapshots.engine_kind = confluence`
# Kapatmak için: 0 / false / no / off. Ham kaynaklar `data_snapshots` + harici çekimler; API: GET /api/v1/analysis/engine/confluence/latest
# QTSS_CONFLUENCE_ENGINE=1
#
# qtss-worker — SPEC_ONCHAIN_SIGNALS: `onchain_signal_scores` tablosu (alt skor kolonları + tarihçe)
# Kapatmak için: QTSS_ONCHAIN_SIGNAL_ENGINE=0
# QTSS_ONCHAIN_SIGNAL_TICK_SECS=60
# Eşik bildirimi (önceki satır |aggregate| ≤ eşik, yeni > eşik): QTSS_NOTIFY_ON_ONCHAIN_SIGNAL=0
# QTSS_NOTIFY_ON_ONCHAIN_SIGNAL_CHANNELS=webhook
# QTSS_ONCHAIN_NOTIFY_THRESHOLD=0.6
# SPEC §10 — eski skor satırlarını silme (varsayılan 7 gün, en az 24 saatte bir)
# QTSS_ONCHAIN_SCORE_RETENTION_DAYS=7
# QTSS_ONCHAIN_SCORE_RETENTION_PRUNE_SECS=86400
# Bileşen ağırlıkları: `app_config` key `onchain_signal_weights` (seed örn. 0031); skor tablosu 0030+, Nansen kolonları 0032+, `engine_symbols` FK 0034/0035, eksik bar_intervals → 0036 — `docs/QTSS_CURSOR_DEV_GUIDE.md` §6
# QTSS_ONCHAIN_SIGNAL_WEIGHTS_KEY=onchain_signal_weights
#
# qtss-worker — Nansen token screener → `nansen_snapshots` (https://docs.nansen.ai/)
# NANSEN_API_KEY=
# NANSEN_API_BASE=https://api.nansen.ai
# Çağrı aralığı sn (kredi için yüksek tutun). Kod varsayılanı 1800 (30 dk).
# NANSEN_TICK_SECS=1800
# Kredi bittiğinde (403) bir sonraki denemeden önce bekleme sn (varsayılan 3600).
# NANSEN_INSUFFICIENT_CREDITS_SLEEP_SECS=3600
# İsteğe bağlı tam JSON; boşsa kod varsayılanı: 5 zincir, 6h, trader_type sm, per_page 100, stabilcoin kapalı.
# NANSEN_TOKEN_SCREENER_REQUEST_JSON=
# Öncelik: app_config (admin PUT /api/v1/config) > bu env > kod varsayılanı. Preset için farklı key: nansen_screener_request_v2
# QTSS_NANSEN_CONFIG_KEY=nansen_screener_request
#
# qtss-worker — Nansen setup scan (token screener + dahili skor → `nansen_setup_*`, migration 0020)
# QTSS_SETUP_SCAN_SECS=900
# QTSS_SETUP_MAX_SNAPSHOT_AGE_SECS=1200
# Setup varsayılanı Nansen’e **ikinci istek göndermez** (yalnız DB snapshot); kredi tek yerde. Canlı yedek: 0
# QTSS_SETUP_SNAPSHOT_ONLY=1
# Setup: HL L/S% Nansen’de yoksa Hyperliquid info (metaAndAssetCtxs) funding proxy — kapatmak için 0
# QTSS_HYPERLIQUID_ENRICH=1
#
# qtss-notify — API `POST /notify/test` ve isteğe bağlı worker sweep uyarıları
# Telegram örnek: QTSS_NOTIFY_TELEGRAM_BOT_TOKEN= QTSS_NOTIFY_TELEGRAM_CHAT_ID=
# Webhook örnek: QTSS_NOTIFY_WEBHOOK_URL=https://...
# QTSS_NOTIFY_WEBHOOK_HEADERS_JSON={"Authorization":"Bearer ..."}
# Diğer kanallar: qtss-notify `config.rs` içindeki QTSS_NOTIFY_* anahtarları
#
# Worker — `notify_outbox` kuyruğu → `qtss-notify` (API `POST /api/v1/notify/outbox` ile doldurulur)
# QTSS_NOTIFY_OUTBOX_ENABLED=0
# QTSS_NOTIFY_OUTBOX_TICK_SECS=10
# (Öncelik: migration 0045 `system_config.worker.notify_outbox_tick_secs`; `QTSS_CONFIG_ENV_OVERRIDES=1` iken env DB’yi geçer.)
#
# Worker — PnL rollup yenileme aralığı (sn); varsayılan 300. Kill switch / günlük PnL gecikmesi için üretimde ayarlayın.
# QTSS_PNL_ROLLUP_TICK_SECS=300
#
# Worker — paper/live pozisyon bildirimi metin dili (`en` / `tr`); DB `worker.notify_default_locale` ile hizalı.
# QTSS_NOTIFY_DEFAULT_LOCALE=tr
#
# qtss-worker — external_data_sources tanımı; ham yanıt `data_snapshots` (migration 0024 ile eski external_data_snapshots kaldırıldı)
# QTSS_EXTERNAL_FETCH=1
# Döngüde kaynak listesi yenileme aralığı sn (varsayılan 30)
# QTSS_EXTERNAL_FETCH_POLL_SECS=30
# Kaynak CRUD: ops rolü ile POST/DELETE /api/v1/analysis/external-fetch/sources
#
# Worker: önceki snapshot’a göre yükselen kenar (false→true) için bildirim
# QTSS_NOTIFY_ON_SWEEP=0
# QTSS_NOTIFY_ON_SWEEP_CHANNELS=webhook
# (virgülle: webhook,telegram,discord)
#
# Worker: Nansen setup taraması sonrası — skor + olasılık eşiği (PLAN Phase D)
# QTSS_NOTIFY_SETUP_ENABLED=0
# QTSS_NOTIFY_SETUP_CHANNELS=telegram
# QTSS_NOTIFY_SETUP_MIN_SCORE=8
# QTSS_NOTIFY_SETUP_MIN_PROBABILITY=45
# (olasılık yüzdesi, 0–100; iç model 0–1)
# QTSS_NOTIFY_SETUP_MAX_ITEMS=5
#
# Worker: dry (paper) dolum → pozisyon özeti bildirimi — SPEC F7 / PLAN Phase D MVP (canlı borsa pozisyonu ayrı faz)
# QTSS_NOTIFY_PAPER_POSITION_ENABLED=0
# QTSS_NOTIFY_PAPER_POSITION_CHANNELS=telegram
# (alternatif isimler: QTSS_NOTIFY_POSITION_ENABLED, QTSS_NOTIFY_POSITION_CHANNELS)
# Döngü aralığı sn (varsayılan 30, en az 10). Öncelik: migration 0046 `worker.paper_position_notify_tick_secs`; `QTSS_CONFIG_ENV_OVERRIDES=1` iken env DB’yi geçer.
# QTSS_NOTIFY_POSITION_TICK_SECS=30
#
# Worker: canlı borsa gerçekleşen emir özeti — PLAN Phase D (`exchange_orders.venue_response`, paper’dan ayrı)
# QTSS_NOTIFY_LIVE_POSITION_ENABLED=0
# QTSS_NOTIFY_LIVE_POSITION_CHANNELS=telegram
# Döngü sn (varsayılan 45, en az 15). Öncelik: migration 0046 `worker.live_position_notify_tick_secs`; `QTSS_CONFIG_ENV_OVERRIDES=1` iken env DB’yi geçer.
# QTSS_NOTIFY_LIVE_TICK_SECS=45
#
# --- QTSS_CURSOR_DEV_GUIDE.md §5 (+ §0 kesin kural) — Nansen genişletme, kline, strateji, risk ---
# Çoklu sembol mum WS (tanımlıysa QTSS_KLINE_SYMBOL yerine kullanılır)
# QTSS_KLINE_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT
# NANSEN_NETFLOWS_TICK_SECS=1800
# NANSEN_PERP_TRADES_TICK_SECS=1800
# NANSEN_FLOW_INTEL_TICK_SECS=900
# NANSEN_WHO_BOUGHT_TICK_SECS=1800
# smart-money/netflow + holdings: JSON array of chain names (default ["ethereum"])
# NANSEN_SMART_MONEY_CHAINS_JSON=["ethereum","solana"]
# tgm/who-bought-sold: chain + token_address zorunlu (veya tek satırda tüm gövde)
# NANSEN_WHO_BOUGHT_CHAIN=ethereum
# NANSEN_WHO_BOUGHT_TOKEN_ADDRESS=0x...
# Alternatif: NANSEN_WHO_BOUGHT_BODY_JSON={"chain":"ethereum","token_address":"0x...","pagination":{"page":1,"per_page":100}}
# Perp PnL leaderboard (TGM): varsayılan api/v1/tgm/perp-pnl-leaderboard; tüm gövde için:
# NANSEN_PERP_LEADERBOARD_BODY_JSON={"token_symbol":"BTC","date":{"from":"2025-03-01","to":"2025-03-29"},"pagination":{"page":1,"per_page":20}}
# veya parça parça: NANSEN_PERP_LEADERBOARD_TOKEN_SYMBOL=BTC NANSEN_PERP_LEADERBOARD_LOOKBACK_DAYS=7
# NANSEN_PERP_LEADERBOARD_PATH=api/v1/tgm/perp-pnl-leaderboard
# Perp leaderboard → app_config whale watchlist
# NANSEN_PERP_LEADERBOARD_ENABLED=1
# NANSEN_PERP_LEADERBOARD_TICK_SECS=604800
# Whale aggregate profiler/perp-positions
# NANSEN_WHALE_PERP_AGGREGATE_ENABLED=1
# NANSEN_WHALE_PERP_POSITIONS_TICK_SECS=1800
#
# Strateji dry döngüleri (qtss-worker; varsayılan kapalı)
# QTSS_STRATEGY_RUNNER_ENABLED=0
# QTSS_STRATEGY_RUNNER_QUOTE_BALANCE_USDT=100000
# Strateji başına ayrı sanal bakiye (yoksa yukarıdaki toplamın 1/4’ü): SIGNAL_FILTER, WHALE_MOMENTUM, ARB_FUNDING, COPY_TRADE
# QTSS_STRATEGY_SIGNAL_FILTER_BALANCE=25000
# QTSS_STRATEGY_WHALE_MOMENTUM_BALANCE=25000
# QTSS_STRATEGY_ARB_FUNDING_BALANCE=25000
# QTSS_STRATEGY_COPY_TRADE_BALANCE=25000
# QTSS_SIGNAL_FILTER_TICK_SECS=60
# QTSS_SIGNAL_FILTER_AUTO_PLACE=0
# QTSS_SIGNAL_FILTER_ON_CONFLICT=half
# QTSS_SIGNAL_FILTER_BRACKET_ORDERS=0
# QTSS_LONG_THRESHOLD=0.6
# QTSS_SHORT_THRESHOLD=-0.6
# QTSS_MIN_SIGNAL_CONFIDENCE=0.4
# QTSS_STRATEGY_ORDER_QTY=0.001
# QTSS_STRATEGY_SKIP_HUMAN_APPROVAL=0
# Kelly ile taban miktar çarpanı (qtss-strategy signal_filter / whale_momentum)
# QTSS_KELLY_APPLY=0
# QTSS_KELLY_WIN_RATE=0.55
# QTSS_KELLY_AVG_WIN_LOSS_RATIO=1.5
# QTSS_KELLY_MAX_FRACTION=0.25
# QTSS_WHALE_MOMENTUM_TICK_SECS=120
# QTSS_WHALE_MOMENTUM_AUTO_PLACE=0
# QTSS_WHALE_MOMENTUM_THRESHOLD=0.45
# QTSS_WHALE_FUNDING_CROWDING_BLOCK=0.0002
# QTSS_ARB_FUNDING_TICK_SECS=300
# QTSS_ARB_FUNDING_THRESHOLD=0.0001
# QTSS_ARB_FUNDING_SYMBOL_BASE=btc
# QTSS_ARB_FUNDING_DRY_TWO_LEG=0
# QTSS_ARB_FUNDING_ORDER_QTY=0.001
# QTSS_COPY_TRADE_STRATEGY_TICK_SECS=120
# QTSS_COPY_TRADE_STRATEGY_AUTO_PLACE=0
# QTSS_COPY_TRADE_DIRECTION_THRESHOLD=0.25
# QTSS_COPY_TRADE_DEFAULT_SYMBOL=BTCUSDT
# QTSS_COPY_TRADE_BASE_QTY=0.001
# QTSS_COPY_TRADE_BAR_EXCHANGE=binance
# QTSS_COPY_TRADE_BAR_SEGMENT=futures
# QTSS_COPY_TRADE_BAR_INTERVAL=1m
#
# Kill switch + pozisyon (worker)
# API: POST /api/v1/admin/kill-switch/reset + JSON {"confirm":true} — app_config kill_switch_trading_halted=false; worker birkaç sn içinde senkronlar
# Öncelik: migration 0047 `worker.kill_switch_db_sync_tick_secs` / `kill_switch_pnl_poll_tick_secs`; `QTSS_CONFIG_ENV_OVERRIDES=1` iken env DB’yi geçer.
# QTSS_KILL_SWITCH_DB_SYNC_SECS=5
# QTSS_KILL_SWITCH_ENABLED=0
# QTSS_KILL_SWITCH_TICK_SECS=60
# QTSS_KILL_SWITCH_DAILY_LOSS_USDT=1000000
# QTSS_KILL_SWITCH_REFERENCE_EQUITY_USDT=100000
# QTSS_MAX_DRAWDOWN_PCT=5.0
# QTSS_POSITION_MANAGER_ENABLED=0
# QTSS_POSITION_MANAGER_TICK_SECS=10
# QTSS_POSITION_MANAGER_BAR_INTERVAL=1m
# QTSS_POSITION_MANAGER_DRY_CLOSE_ENABLED=0
# Dry açıkken yalnız dry yol kullanılır. Canlı reduce-only market kapatma (exchange_accounts gerekir); trading halted iken atlanır:
# QTSS_POSITION_MANAGER_LIVE_CLOSE_ENABLED=0
# QTSS_DEFAULT_STOP_LOSS_PCT=2.0
# QTSS_DEFAULT_TAKE_PROFIT_PCT=4.0
# QTSS_MAX_POSITION_NOTIONAL_USDT=10000
# QTSS_DEFAULT_LEVERAGE=3
#
# === AI (qtss-ai, çoklu sağlayıcı + on-prem) — `app_config.ai_engine_config` + env birleşimi; ayrıntı: docs/QTSS_MASTER_DEV_GUIDE.md §6.0
# Worker döngülerini tamamen kapatmak için: QTSS_AI_ENGINE_WORKER=0
# QTSS_AI_ENGINE_WORKER=1
# Anahtar / uçlar (kullanılmayan sağlayıcılar boş kalabilir):
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# Alternatif isim: QTSS_AI_ANTHROPIC_API_KEY, QTSS_AI_ANTHROPIC_BASE_URL, QTSS_AI_ANTHROPIC_TIMEOUT_SECS=120
# OpenAI uyumlu (vLLM / LM Studio / dahili gateway): QTSS_AI_OPENAI_COMPAT_BASE_URL=https://api.example.internal/v1
# QTSS_AI_OPENAI_COMPAT_HEADERS_JSON=
# Ollama: QTSS_AI_OLLAMA_BASE_URL=http://127.0.0.1:11434
# On-prem: QTSS_AI_ONPREM_TIMEOUT_SECS=180 QTSS_AI_ONPREM_MAX_IN_FLIGHT=4 QTSS_AI_ONPREM_API_KEY=
# Katman devre dışı (üstüne `.env`): QTSS_AI_DISABLED=1 veya app_config enabled:false
# QTSS_AI_ENABLED=1
# QTSS_AI_PROVIDER_TACTICAL=anthropic
# QTSS_AI_PROVIDER_OPERATIONAL=anthropic
# QTSS_AI_PROVIDER_STRATEGIC=anthropic
# QTSS_AI_MODEL_TACTICAL=claude-haiku-4-5-20251001
# QTSS_AI_MODEL_OPERATIONAL=claude-haiku-4-5-20251001
# QTSS_AI_MODEL_STRATEGIC=claude-sonnet-4-20250514
# QTSS_AI_TACTICAL_TICK_SECS=900
# QTSS_AI_OPERATIONAL_TICK_SECS=120
# QTSS_AI_STRATEGIC_TICK_SECS=86400
# QTSS_AI_AUTO_APPROVE_ENABLED=0
# QTSS_AI_AUTO_APPROVE_THRESHOLD=0.85
# QTSS_AI_MIN_CONFIDENCE=0.60
# QTSS_AI_STRATEGIC_ENABLED=0
# QTSS_AI_MAX_POSITION_SIZE_MULT=1.5
# Karar TTL: `app_config` → `ai_engine_config.decision_ttl_secs` (env ile tam üzerine yazma yok; `AiEngineConfig` DB + merge)
# Çıktı dili ipucu (prompt): QTSS_AI_OUTPUT_LOCALE=tr
#
# Copy follower (abonelik + Nansen gecikme; worker)
# Copy trade — leader fill → DB job queue (`copy_trade_execution_jobs`); tüketici isteğe bağlı dry place
# QTSS_COPY_TRADE_QUEUE_ENABLED=0
# QTSS_COPY_TRADE_QUEUE_TICK_SECS=20
# QTSS_COPY_TRADE_QUEUE_SCAN_LIMIT=400
# QTSS_COPY_TRADE_QUEUE_SCAN_LOOKBACK_HOURS=168
# QTSS_COPY_TRADE_QUEUE_AUTO_PLACE=0
#
# QTSS_COPY_TRADE_FOLLOWER_ENABLED=0
# QTSS_COPY_TRADE_FOLLOWER_TICK_SECS=300
# QTSS_COPY_TRADE_FOLLOWER_AUTO_PLACE=0
