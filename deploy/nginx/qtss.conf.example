## QTSS reverse proxy — v1 + v2 side-by-side
##
## Single qtss-api binary serves BOTH v1 and v2 routes (/v2/* added in Faz 7.x–8.0).
## v1 frontend: web/        → Vite preview on :4173
## v2 frontend: web-v2/     → Vite preview on :4174
##
## Routing strategy: path-based.
##   /            → v1 web (default, backwards compatible)
##   /v2/         → v2 web
##   /api/        → qtss-api (shared; serves /v2/* sub-routes too)
##   /health,
##   /live,
##   /ready,
##   /metrics     → qtss-api
##
## Place this file in /etc/nginx/conf.d/qtss.conf and reload:
##   sudo nginx -t && sudo systemctl reload nginx

upstream qtss_api { server 127.0.0.1:8080; }
upstream qtss_web_v1 { server 127.0.0.1:4173; }
upstream qtss_web_v2 { server 127.0.0.1:4174; }

server {
    listen 80;
    server_name _;  # replace with prod hostname

    client_max_body_size 16m;

    # ── API (shared by both frontends) ────────────────────────────
    location /api/ {
        proxy_pass         http://qtss_api/;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    location ~ ^/(health|live|ready|metrics)$ {
        proxy_pass         http://qtss_api;
        proxy_set_header   Host $host;
    }

    # ── v2 frontend (Faz 8.0+) ────────────────────────────────────
    location /v2/ {
        proxy_pass         http://qtss_web_v2/;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Forwarded-Proto $scheme;
        # Vite HMR / SSE
        proxy_set_header   Upgrade   $http_upgrade;
        proxy_set_header   Connection "upgrade";
    }

    # ── v1 frontend (default, legacy) ─────────────────────────────
    location / {
        proxy_pass         http://qtss_web_v1;
        proxy_http_version 1.1;
        proxy_set_header   Host              $host;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   Upgrade   $http_upgrade;
        proxy_set_header   Connection "upgrade";
    }
}

## Rollback note:
##   v2 ekibi sorun yaşarsa /v2/ location bloğu yorumlanıp nginx reload edilir.
##   v1 trafiği etkilenmez.  qtss-api ortak olduğu için API tarafı her zaman ayakta.
